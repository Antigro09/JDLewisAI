# ---- Database (Neon / Postgres) ----
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection used for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Auth ----
# 32+ char random string used to sign session JWTs (openssl rand -base64 32).
AUTH_SECRET="change-me-to-a-long-random-string"
# Used to encrypt OAuth refresh tokens at rest (32-byte base64). openssl rand -base64 32
ENCRYPTION_KEY="change-me-to-a-32-byte-base64-key"
# Set to "true" ONLY for temporary plain-HTTP testing (e.g. a bare EC2 instance with
# no TLS-terminating load balancer/reverse proxy in front of it) — browsers refuse to
# store a Secure cookie over plain HTTP, which breaks login entirely otherwise. Leave
# unset for any real deployment that serves the app over HTTPS.
DISABLE_SECURE_COOKIES=""

# ---- Anthropic (company key, server-side only) ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Material takeoff engine ----
# Separate no-auth FastAPI service. Keep this private-network/localhost in every environment.
TAKEOFF_ENGINE_URL="http://localhost:8000"

# ---- Seed admin (used by `npm run db:seed`) ----
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Administrator"

# ---- Google OAuth (Phase 2 — per-user Drive/Docs/Sheets/Gmail) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
GOOGLE_AUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ---- Automations (Phase 3) ----
# Shared secret the scheduler must send as `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this automatically when CRON_SECRET is set. openssl rand -hex 32
CRON_SECRET="change-me-to-a-long-random-string"

# ---- Voice / Text-to-speech (Phase 7, optional) ----
# For natural, human-sounding voice replies. Set ONE provider; ElevenLabs is
# preferred when both are present. Without either, the app falls back to the
# browser's built-in (robotic) speech synthesis.
#
# ElevenLabs (most human):
ELEVENLABS_API_KEY=""
# Optional — defaults to the "Rachel" voice and the turbo v2.5 model.
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL=""
#
# OpenAI TTS (also very natural):
OPENAI_API_KEY=""
# Optional — defaults to voice "nova", model "gpt-4o-mini-tts".
TTS_VOICE=""
TTS_MODEL=""

# ---- Meeting Intelligence ----
# Live streaming transcription (speech-to-text).
ASSEMBLYAI_API_KEY=""
#
# Semantic meeting memory & RAG (spec §12/§13) via pgvector. Requires the
# pgvector extension — run once on the DB: CREATE EXTENSION IF NOT EXISTS vector;
# Embeddings use an OpenAI-compatible endpoint; falls back to Postgres full-text
# search when unset.
EMBEDDINGS_API_KEY=""            # falls back to OPENAI_API_KEY if empty
EMBEDDINGS_MODEL=""              # default text-embedding-3-small (1536 dims)
EMBEDDINGS_BASE_URL=""           # default https://api.openai.com/v1
#
# Automatic speaker identification (voiceprints). Point at your speaker-embedding
# service (ECAPA-TDNN / pyannote / NeMo): it receives audio, returns an embedding.
# Without it, speakers are named manually (and remembered company-wide).
VOICEPRINT_EMBED_URL=""
VOICEPRINT_API_KEY=""

# ---- Desktop-only production ----
# When set, ONLY the Electron desktop shell can reach the app: middleware
# requires this value in the x-desktop-key header, browsers get a bare 404,
# and public signup (password + Google) is disabled — the owner provisions
# accounts from /owner. Leave UNSET for local dev so the web app works in a
# browser. Must match the secret baked into the exe (electron/app-config.json,
# written by CI from repo secrets). openssl rand -hex 32
DESKTOP_GATE_SECRET=""
# Fine-grained GitHub PAT (contents: read) on the releases repo, so the
# license-gated update proxy can read GitHub Releases once the repo is private.
GITHUB_RELEASES_TOKEN=""
# "owner/repo" hosting desktop installers. Default: Antigro09/JDLewisAI
GITHUB_RELEASES_REPO=""

# ---- App ----
NEXT_PUBLIC_APP_NAME="ContractorAI"
