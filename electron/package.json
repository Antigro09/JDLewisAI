{
  "name": "contractor-ai-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for ContractorAI with Meeting Intelligence integration.",
  "author": "ContractorAI",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.contractorai.desktop",
    "productName": "ContractorAI",
    "files": [
      "main.js",
      "preload.js",
      "error.html",
      "README.md"
    ],
    "publish": {
      "provider": "github",
      "owner": "Antigro09",
      "repo": "JDLewisAI"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  }
}
