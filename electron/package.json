{
  "name": "contractor-ai-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop shell for ContractorAI with Meeting Intelligence integration.",
  "author": "ContractorAI",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.contractorai.desktop",
    "productName": "ContractorAI",
    "files": [
      "main.js",
      "preload.js",
      "error.html",
      "app-config.json",
      "README.md"
    ],
    "publish": {
      "provider": "github",
      "owner": "Antigro09",
      "repo": "JDLewisAI"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "license": "build/license.txt",
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ContractorAI-Setup-${version}.${ext}",
      "shortcutName": "ContractorAI",
      "createDesktopShortcut": "always",
      "runAfterFinish": true
    }
  }
}
