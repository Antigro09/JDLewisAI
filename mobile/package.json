{
  "name": "contractor-ai-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor native shells (iOS + Android) that load the deployed ContractorAI web app via server.url",
  "scripts": {
    "sync": "cap sync",
    "android": "cap run android",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "assets": "capacitor-assets generate --assetPath assets --iconBackgroundColor '#ea580c' --iconBackgroundColorDark '#431407'"
  },
  "dependencies": {
    "@capacitor/android": "^7",
    "@capacitor/core": "^7",
    "@capacitor/ios": "^7"
  },
  "devDependencies": {
    "@capacitor/assets": "^3",
    "@capacitor/cli": "^7",
    "typescript": "^5"
  }
}
