# --- Database ---------------------------------------------------------------
# The engine owns its own database. Create a `takeoff` database inside the
# SAME Postgres cluster the main app uses (Neon: create a second database in
# the project) and point this URL at it. Never reuse the app's database.
TAKEOFF_DATABASE_URL=postgresql+psycopg://takeoff:takeoff@localhost:5433/takeoff

# --- Storage / jobs -----------------------------------------------------------
TAKEOFF_STORAGE_ROOT=data
TAKEOFF_JOB_QUEUE=local            # local | rq
# TAKEOFF_REDIS_URL=redis://localhost:6379/0

# --- Adapter transports: mock | sagemaker | openai_compat | local -------------
TAKEOFF_OCR_TRANSPORT=mock
TAKEOFF_DETECTOR_TRANSPORT=mock
TAKEOFF_SEGMENTER_TRANSPORT=mock
TAKEOFF_VLM_TRANSPORT=mock
TAKEOFF_ROLLUP_TRANSPORT=mock

# --- Local (in-process) weights — used when a *_TRANSPORT above is "local" -----
# Download the weights (see training/README.md + docs/adapters.md) and point at
# the FILE PATHS here. OCR/PaddleOCR fetches its own weights on first run.
#   pip install -e ".[ocr,detect,segment]"
# TAKEOFF_DETECTOR_TRANSPORT=local
# TAKEOFF_DETECTOR_CHECKPOINT=/models/rf-detr-construction.pth   # your fine-tuned RF-DETR
# TAKEOFF_SEGMENTER_TRANSPORT=local
# TAKEOFF_SEGMENTER_CHECKPOINT=/models/sam2_hiera_small.pt
# TAKEOFF_SEGMENTER_MODEL_CFG=sam2_hiera_s.yaml

# --- SageMaker endpoints (primary hosted-model path). Value = ENDPOINT NAME. ---
# Credentials come from the standard boto3 chain (env/instance profile/~/.aws).
TAKEOFF_AWS_REGION=us-east-1
# TAKEOFF_OCR_SAGEMAKER_ENDPOINT=paddleocr-serverless
# TAKEOFF_DETECTOR_SAGEMAKER_ENDPOINT=rf-detr-construction
# TAKEOFF_SEGMENTER_SAGEMAKER_ENDPOINT=sam2-hiera-base
# TAKEOFF_VLM_SAGEMAKER_ENDPOINT=qwen3-vl-8b            # real-time, not serverless
# TAKEOFF_ROLLUP_SAGEMAKER_ENDPOINT=llama-3-3-70b       # real-time, not serverless

# --- OpenAI-compatible endpoints (vLLM/TGI alternative) -------------------------
# TAKEOFF_VLM_OPENAI_BASE_URL=http://vllm-host:8000/v1
# TAKEOFF_VLM_OPENAI_MODEL=Qwen/Qwen3-VL-8B-Instruct
# TAKEOFF_ROLLUP_OPENAI_BASE_URL=http://vllm-host:8001/v1
# TAKEOFF_ROLLUP_OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Tuning ---------------------------------------------------------------------
TAKEOFF_RENDER_DPI=150
TAKEOFF_REVIEW_CONFIDENCE_THRESHOLD=0.75
TAKEOFF_DEFAULT_FLOORING_WASTE_FACTOR=1.10
TAKEOFF_DEFAULT_SLAB_THICKNESS_IN=4.0
